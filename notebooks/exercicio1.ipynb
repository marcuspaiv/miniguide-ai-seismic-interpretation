        "import cv2\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Carregar imagem\n",
        "img = cv2.imread('/content/lamina_alunos.jpg')\n",
        "img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
        "\n",
        "# Mostrar imagem\n",
        "plt.imshow(img)\n",
        "plt.title('Thin Section Image')\n",
        "plt.axis('off')"
      ]
